    "border": "#2A2A4A",
}

SEVERITY_COLORS = {
    "CRITIQUE": "#FF4444",
    "ÉLEVÉ": "#FF6B35",
    "MOYEN": "#FFD700",
    "INFO": "#00D4FF",
}

OPERATORS = [
    ("site:", "Domaine cible"),
    ("filetype:", "Type de fichier"),
    ("intitle:", "Titre de la page"),
    ("inurl:", "Dans l'URL"),
    ("intext:", "Dans le contenu"),
    ("inurl:", "Dans l'URL"),
    ("cache:", "Version en cache"),
    ("related:", "Sites similaires"),
    ("AROUND(N)", "Proximité de mots"),
    ('"phrase"', "Phrase exacte"),
    ("-mot", "Exclure un mot"),
    ("OR", "Opérateur OU"),
]

DATA_DIR = os.path.join(os.path.dirname(os.path.dirname(os.path.abspath(__file__))), "data")
DORK_LIB_PATH = os.path.join(DATA_DIR, "dork_library.json")


class DorkingApp(ctk.CTk):
    def __init__(self):
        super().__init__()
        ctk.set_appearance_mode("dark")
        ctk.set_default_color_theme("dark-blue")

        self.config = load_config()
        self.dork_library = self._load_dork_library()
        self.engine = None
        self.search_results: dict[str, list[SearchResult]] = {}
        self.watchdog: WatchdogManager | None = None
        self._build_engine()

        self.title("Dorking Tool — OSINT & Security Research")
        self.geometry("1400x900")
        self.minsize(1100, 700)
        self.configure(fg_color=COLORS["bg_dark"])

        self._build_ui()
        self._init_watchdog()

    def _load_dork_library(self) -> dict:
        if os.path.exists(DORK_LIB_PATH):
            with open(DORK_LIB_PATH, "r", encoding="utf-8") as f:
                return json.load(f)
        return {"categories": {}, "operators": {}, "stacks": {}}

    def _build_engine(self):
        self.engine = MultiEngine({
            "google_api_key": self.config.google_api_key,
            "google_cse_id": self.config.google_cse_id,
            "bing_api_key": self.config.bing_api_key,
            "shodan_api_key": self.config.shodan_api_key,
        })

    def _init_watchdog(self):
        watchdog_path = os.path.join(DATA_DIR, "watchdog_jobs.json")
        self.watchdog = WatchdogManager(watchdog_path, self._watchdog_search)
        self.watchdog.start_all()

    def _watchdog_search(self, dork: str, engines: list[str]):
        if self.engine:
            return self.engine.search(dork, engines=engines, max_results=5)
        return {}

    def _build_ui(self):
        self.grid_columnconfigure(1, weight=1)
        self.grid_rowconfigure(0, weight=1)

        self._build_sidebar()
        self._build_main_area()

    def _build_sidebar(self):
        sidebar = ctk.CTkFrame(self, width=220, fg_color=COLORS["bg_panel"], corner_radius=0)
        sidebar.grid(row=0, column=0, sticky="nsew")
        sidebar.grid_rowconfigure(10, weight=1)

        logo_frame = ctk.CTkFrame(sidebar, fg_color="transparent")
        logo_frame.grid(row=0, column=0, padx=20, pady=(20, 10), sticky="ew")

        ctk.CTkLabel(logo_frame, text="◈ DORKING", font=ctk.CTkFont("Consolas", 20, "bold"),
                      text_color=COLORS["accent"]).pack(anchor="w")
        ctk.CTkLabel(logo_frame, text="OSINT & Security Tool",
                      font=ctk.CTkFont(size=10), text_color=COLORS["text_dim"]).pack(anchor="w")

        ctk.CTkFrame(sidebar, height=1, fg_color=COLORS["border"]).grid(
            row=1, column=0, sticky="ew", padx=10, pady=5)

        nav_items = [
            ("🔍  Dork Builder", "builder"),
            ("📚  Bibliothèque", "library"),
            ("🔣  Opérateurs", "operators"),
            ("📖  Wiki", "wiki"),
            ("🤖  IA Suggest", "suggest"),
            ("👁  Watchdog", "watchdog"),
            ("📊  Résultats", "results"),
            ("⚙️  Paramètres", "settings"),
        ]

        self.nav_buttons = {}
        for i, (label, key) in enumerate(nav_items):
            btn = ctk.CTkButton(
                sidebar, text=label, anchor="w",
                font=ctk.CTkFont("Consolas", 13),
                fg_color="transparent",
                text_color=COLORS["text"],
                hover_color=COLORS["bg_card"],
                command=lambda k=key: self._show_tab(k),
                height=38
            )
            btn.grid(row=i + 2, column=0, padx=10, pady=2, sticky="ew")
            self.nav_buttons[key] = btn

        ctk.CTkFrame(sidebar, height=1, fg_color=COLORS["border"]).grid(
            row=11, column=0, sticky="ew", padx=10, pady=5)

        warning = ctk.CTkLabel(
            sidebar,
            text="⚠️ Usage légal uniquement\nAudit autorisé & OSINT",
            font=ctk.CTkFont(size=9),
            text_color=COLORS["warning"],
            justify="center"
        )
        warning.grid(row=12, column=0, padx=10, pady=10)

    def _build_main_area(self):
        main = ctk.CTkFrame(self, fg_color=COLORS["bg_dark"], corner_radius=0)
        main.grid(row=0, column=1, sticky="nsew")
        main.grid_columnconfigure(0, weight=1)
        main.grid_rowconfigure(0, weight=1)

        self.frames = {}
        for key, cls in [
            ("builder",   BuilderFrame),
            ("library",   LibraryFrame),
            ("operators", OperatorsFrame),
            ("wiki",      WikiFrame),
            ("suggest",   SuggestFrame),
            ("watchdog",  WatchdogFrame),
            ("results",   ResultsFrame),
            ("settings",  SettingsFrame),
        ]:
            f = cls(main, self)
            f.grid(row=0, column=0, sticky="nsew")
            self.frames[key] = f

        self._show_tab("builder")

    def _show_tab(self, key: str):
        for k, btn in self.nav_buttons.items():
            btn.configure(
                fg_color=COLORS["bg_card"] if k == key else "transparent",
                text_color=COLORS["accent"] if k == key else COLORS["text"]
            )
        for k, frame in self.frames.items():
            if k == key:
                frame.tkraise()
                if hasattr(frame, "on_show"):
                    frame.on_show()

    def run_search(self, dork: str, engines: list[str] | None = None, max_results: int = 10):
        self.search_results = {}
        self._show_tab("results")
        self.frames["results"].start_search(dork, engines, max_results)

    def get_search_results(self):
        return self.search_results


