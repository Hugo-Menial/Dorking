    def __init__(self, parent, app: "DorkingApp"):
        super().__init__(parent, fg_color=COLORS["bg_dark"])
        self.app = app
        self._active_section = "all"
        self.grid_columnconfigure(0, weight=1)
        self.grid_rowconfigure(2, weight=1)
        self._build()

    def _build(self):
        # ── En-tête ──────────────────────────────────────────────────────
        header = ctk.CTkFrame(self, fg_color=COLORS["bg_panel"])
        header.grid(row=0, column=0, sticky="ew")
        header.grid_columnconfigure(0, weight=1)

        ctk.CTkLabel(header, text="📖 Wiki — Référence des Opérateurs",
                      font=ctk.CTkFont("Consolas", 22, "bold"),
                      text_color=COLORS["accent"]).grid(
            row=0, column=0, padx=20, pady=(15, 2), sticky="w")
        ctk.CTkLabel(header,
                      text="Documentation complète avec exemples pratiques, recettes OSINT et boutons Try",
                      font=ctk.CTkFont(size=12), text_color=COLORS["text_dim"]).grid(
            row=1, column=0, padx=20, pady=(0, 10), sticky="w")

        self._search_var = ctk.StringVar()
        ctk.CTkEntry(header, textvariable=self._search_var,
                      placeholder_text="Rechercher un opérateur, technique, exemple...",
                      fg_color=COLORS["bg_input"], border_color=COLORS["border"],
                      text_color=COLORS["text"], height=34, width=340).grid(
            row=0, column=1, padx=20, pady=(15, 2), rowspan=2, sticky="e")
        self._search_var.trace_add("write", lambda *_: self._render())

        # ── Onglets de sections ───────────────────────────────────────────
        tabs_frame = ctk.CTkFrame(self, fg_color=COLORS["bg_panel"])
        tabs_frame.grid(row=1, column=0, sticky="ew")
        tabs_inner = ctk.CTkFrame(tabs_frame, fg_color="transparent")
        tabs_inner.pack(side="left", padx=16, pady=8)

        self._tab_btns: dict[str, tuple] = {}
        sections_nav = [("all", "  Tout  ", "#888888")] + [
            (s["id"], f" {s['icon']} {s['title']} ", s["color"])
            for s in self._CONTENT
        ]
        for sid, label, color in sections_nav:
            active = sid == "all"
            btn = ctk.CTkButton(
                tabs_inner, text=label,
                font=ctk.CTkFont("Consolas", 10),
                fg_color=COLORS["bg_card"] if active else "transparent",
                text_color=COLORS["accent"] if active else COLORS["text_dim"],
                hover_color=COLORS["bg_card"],
                height=28, corner_radius=4,
                command=lambda s=sid: self._select(s)
            )
            btn.pack(side="left", padx=(0, 4))
            self._tab_btns[sid] = (btn, color)

        # ── Zone scrollable ───────────────────────────────────────────────
        self._scroll = ctk.CTkScrollableFrame(self, fg_color=COLORS["bg_dark"])
        self._scroll.grid(row=2, column=0, sticky="nsew")
        self._scroll.grid_columnconfigure(0, weight=1)
        self._render()

    def _select(self, section_id: str):
        self._active_section = section_id
        self._search_var.set("")
        for sid, (btn, _) in self._tab_btns.items():
            active = sid == section_id
            btn.configure(
                fg_color=COLORS["bg_card"] if active else "transparent",
                text_color=COLORS["accent"] if active else COLORS["text_dim"],
            )
        self._render()

    def _render(self):
        for w in self._scroll.winfo_children():
            w.destroy()
        q = self._search_var.get().strip().lower()
        row = 0

        for section in self._CONTENT:
            if self._active_section not in ("all", section["id"]):
                continue
            entries = section["entries"]
            if q:
                entries = [
                    e for e in entries
                    if q in e["op"].lower()
                    or q in e.get("desc", "").lower()
                    or any(q in ex.lower() for _, ex in e.get("examples", []))
                    or q in e.get("tip", "").lower()
                ]
            if not entries:
                continue

            # En-tête de section
            sh = ctk.CTkFrame(self._scroll, fg_color="transparent")
            sh.grid(row=row, column=0, padx=20, pady=(22, 4), sticky="ew")
            sh.grid_columnconfigure(1, weight=1)
            ctk.CTkLabel(sh, text=f"  {section['icon']} {section['title']}  ",
                          font=ctk.CTkFont("Consolas", 13, "bold"),
                          fg_color=section["color"], text_color="#000000",
                          corner_radius=4).grid(row=0, column=0, sticky="w")
            ctk.CTkFrame(sh, height=1, fg_color=COLORS["border"]).grid(
                row=0, column=1, padx=(12, 0), sticky="ew")
            row += 1

            if section.get("intro") and not q:
                ctk.CTkLabel(self._scroll, text=section["intro"],
                              font=ctk.CTkFont(size=11), text_color=COLORS["text_dim"],
                              wraplength=960, justify="left").grid(
                    row=row, column=0, padx=24, pady=(0, 8), sticky="w")
                row += 1

            for entry in entries:
                self._entry_card(row, entry, section["color"])
                row += 1

        if row == 0:
            ctk.CTkLabel(self._scroll, text="Aucun résultat pour cette recherche.",
                          font=ctk.CTkFont(size=12), text_color=COLORS["text_dim"]).grid(
                row=0, column=0, padx=20, pady=60)

    def _entry_card(self, row: int, entry: dict, color: str):
        card = ctk.CTkFrame(self._scroll, fg_color=COLORS["bg_card"],
                             corner_radius=8, border_width=1, border_color=COLORS["border"])
        card.grid(row=row, column=0, padx=20, pady=5, sticky="ew")
        card.grid_columnconfigure(1, weight=1)

        # Badge gauche
        badge = ctk.CTkFrame(card, fg_color=COLORS["bg_input"], corner_radius=6, width=195)
        badge.grid(row=0, column=0, rowspan=3, padx=(12, 8), pady=14, sticky="n")
        badge.grid_propagate(False)
        ctk.CTkLabel(badge, text=entry["op"],
                      font=ctk.CTkFont("Consolas", 11, "bold"),
                      text_color=color, wraplength=178,
                      justify="center").pack(padx=6, pady=(10, 3))
        ctk.CTkLabel(badge, text=entry["syntax"],
                      font=ctk.CTkFont("Consolas", 9),
                      text_color=COLORS["text_dim"],
                      wraplength=178, justify="center").pack(padx=6, pady=(0, 10))

        # Description
        ctk.CTkLabel(card, text=entry["desc"],
                      font=ctk.CTkFont(size=12), text_color=COLORS["text"],
                      wraplength=740, justify="left").grid(
            row=0, column=1, padx=(0, 14), pady=(14, 6), sticky="w")

        # Exemples
        if entry.get("examples"):
            ex_wrap = ctk.CTkFrame(card, fg_color="transparent")
            ex_wrap.grid(row=1, column=1, padx=(0, 14), pady=(0, 4), sticky="ew")
            ex_wrap.grid_columnconfigure(0, weight=1)
            for label, code in entry["examples"]:
                row_f = ctk.CTkFrame(ex_wrap, fg_color=COLORS["bg_dark"], corner_radius=4)
                row_f.pack(fill="x", pady=2)
                ctk.CTkLabel(row_f, text=f"  {label}",
                              font=ctk.CTkFont(size=9), text_color=COLORS["text_dim"],
                              width=168, anchor="w").pack(side="left")
                ctk.CTkLabel(row_f, text=code,
                              font=ctk.CTkFont("Consolas", 10), text_color=COLORS["accent"],
                              anchor="w").pack(side="left", padx=8, fill="x", expand=True)
                ctk.CTkButton(row_f, text="↗ Try",
                               font=ctk.CTkFont("Consolas", 9),
                               fg_color="transparent", text_color=color,
                               hover_color=COLORS["border"], height=22, width=55,
                               command=lambda c=code: self._try(c)).pack(side="right", padx=4, pady=2)

        # Tip OSINT
        if entry.get("tip"):
            tip = ctk.CTkFrame(card, fg_color="#0D1A0D", corner_radius=4)
            tip.grid(row=2, column=1, padx=(0, 14), pady=(0, 14), sticky="ew")
            ctk.CTkLabel(tip, text="💡  " + entry["tip"],
                          font=ctk.CTkFont(size=10), text_color="#88CC88",
                          wraplength=730, justify="left").pack(padx=10, pady=7, anchor="w")

    def _try(self, code: str):
        self.app.frames["builder"].query_var.set(code)
        self.app._show_tab("builder")


class SettingsFrame(ctk.CTkFrame):
    def __init__(self, parent, app: DorkingApp):
        super().__init__(parent, fg_color=COLORS["bg_dark"])
        self.app = app
        self.grid_columnconfigure(0, weight=1)
        self.grid_rowconfigure(1, weight=1)
        self._build()

    def _build(self):
        header = ctk.CTkFrame(self, fg_color=COLORS["bg_panel"])
        header.grid(row=0, column=0, sticky="ew")
        ctk.CTkLabel(header, text="⚙️ Paramètres",
                      font=ctk.CTkFont("Consolas", 22, "bold"),
                      text_color=COLORS["accent"]).grid(row=0, column=0, padx=20, pady=(15, 2), sticky="w")
        ctk.CTkLabel(header, text="Clés API et configuration",
                      font=ctk.CTkFont(size=12), text_color=COLORS["text_dim"]).grid(
            row=1, column=0, padx=20, pady=(0, 12), sticky="w")

        scroll = ctk.CTkScrollableFrame(self, fg_color=COLORS["bg_dark"])
        scroll.grid(row=1, column=0, sticky="nsew")
        scroll.grid_columnconfigure(0, weight=1)

        apis = [
            ("Google CSE API Key", "google_api_key",
             "Obtenez votre clé sur console.cloud.google.com (Custom Search API)"),
            ("Google CSE ID (cx)", "google_cse_id",
             "ID du moteur de recherche personnalisé (cx=...)"),
            ("Bing API Key", "bing_api_key",
             "Azure Cognitive Services > Bing Search v7"),
            ("Shodan API Key", "shodan_api_key",
             "account.shodan.io > My Account > API Key"),
            ("Anthropic API Key", "anthropic_api_key",
             "console.anthropic.com > API Keys (pour Dork Suggest IA)"),
        ]

        self.settings_vars = {}
        for i, (label, key, hint) in enumerate(apis):
            card = ctk.CTkFrame(scroll, fg_color=COLORS["bg_card"], corner_radius=8)
            card.grid(row=i, column=0, padx=20, pady=6, sticky="ew")
            card.grid_columnconfigure(1, weight=1)

            ctk.CTkLabel(card, text=label, font=ctk.CTkFont("Consolas", 12, "bold"),
                          text_color=COLORS["text"]).grid(row=0, column=0, columnspan=2,
                                                          padx=15, pady=(10, 2), sticky="w")
            ctk.CTkLabel(card, text=hint, font=ctk.CTkFont(size=9),
                          text_color=COLORS["text_dim"]).grid(row=1, column=0, columnspan=2,
                                                              padx=15, pady=(0, 4), sticky="w")
            var = ctk.StringVar(value=getattr(self.app.config, key, ""))
            entry = ctk.CTkEntry(card, textvariable=var, font=ctk.CTkFont("Consolas", 11),
                                  fg_color=COLORS["bg_input"], border_color=COLORS["border"],
                                  text_color=COLORS["text"], height=34, show="*" if "key" in key.lower() else "")
            entry.grid(row=2, column=0, padx=15, pady=(0, 12), sticky="ew")

            show_btn = ctk.CTkButton(card, text="👁", width=34, height=34,
                                      fg_color=COLORS["bg_input"], text_color=COLORS["text"],
                                      hover_color=COLORS["border"],
                                      command=lambda e=entry: e.configure(show="" if e.cget("show") else "*"))
            show_btn.grid(row=2, column=1, padx=(0, 15), pady=(0, 12), sticky="w")
            self.settings_vars[key] = var

        from core.config_manager import keyring_status
        kr = keyring_status()
        kr_color = COLORS["success"] if kr["available"] else COLORS["warning"]
        kr_card = ctk.CTkFrame(scroll, fg_color=COLORS["bg_card"], corner_radius=8,
                                border_color=kr_color, border_width=1)
        kr_card.grid(row=len(apis), column=0, padx=20, pady=6, sticky="ew")
        ctk.CTkLabel(kr_card, text="🔐 Sécurité des clés API",
                      font=ctk.CTkFont("Consolas", 12, "bold"),
                      text_color=COLORS["text"]).grid(row=0, column=0, padx=15, pady=(10, 4), sticky="w")
        ctk.CTkLabel(kr_card, text=kr["message"],
                      font=ctk.CTkFont(size=10), text_color=kr_color).grid(
            row=1, column=0, padx=15, pady=(0, 10), sticky="w")

        ctk.CTkButton(scroll, text="💾 Sauvegarder la configuration",
                       font=ctk.CTkFont("Consolas", 13, "bold"),
                       fg_color=COLORS["success"], text_color="#000000",
                       hover_color="#00CC70", height=44,
                       command=self._save).grid(row=len(apis) + 1, column=0, padx=20, pady=(10, 5), sticky="ew")

        legal_card = ctk.CTkFrame(scroll, fg_color="#1A0A00", corner_radius=8,
                                   border_color=COLORS["warning"], border_width=1)
        legal_card.grid(row=len(apis) + 2, column=0, padx=20, pady=(10, 20), sticky="ew")

        ctk.CTkLabel(legal_card, text="⚠️ Avertissement légal",
                      font=ctk.CTkFont("Consolas", 12, "bold"),
                      text_color=COLORS["warning"]).grid(row=0, column=0, padx=15, pady=(12, 4), sticky="w")

        legal_text = (
            "Cet outil est destiné exclusivement à la cybersécurité défensive, aux audits de sécurité "
            "autorisés, et à la recherche OSINT légale.\n\n"
            "L'utilisation de Google Dorks pour accéder à des données privées, des systèmes tiers "
            "sans autorisation explicite, ou pour toute activité malveillante est ILLÉGALE et peut "
            "entraîner des poursuites pénales (Computer Fraud and Abuse Act, loi Godfrain, RGPD).\n\n"
            "Utilisez uniquement sur des systèmes dont vous êtes propriétaire ou pour lesquels "
            "vous disposez d'une autorisation écrite."
        )
        ctk.CTkLabel(legal_card, text=legal_text, font=ctk.CTkFont(size=10),
                      text_color=COLORS["text_dim"], wraplength=700, justify="left").grid(
            row=1, column=0, padx=15, pady=(0, 15), sticky="w")

    def _save(self):
        for key, var in self.settings_vars.items():
            setattr(self.app.config, key, var.get().strip())
        save_config(self.app.config)
        self.app._build_engine()
        messagebox.showinfo("Sauvegardé", "Configuration sauvegardée. Les moteurs ont été rechargés.")
