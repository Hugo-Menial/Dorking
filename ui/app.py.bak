        query_card.grid(row=0, column=0, padx=20, pady=(20, 10), sticky="ew")
        query_card.grid_columnconfigure(0, weight=1)

        ctk.CTkLabel(query_card, text="Requête Dork",
                      font=ctk.CTkFont("Consolas", 13, "bold"), text_color=COLORS["text"]).grid(
            row=0, column=0, padx=15, pady=(12, 5), sticky="w")

        self.query_var = ctk.StringVar()
        self.query_entry = ctk.CTkEntry(
            query_card, textvariable=self.query_var,
