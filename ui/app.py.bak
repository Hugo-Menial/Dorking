                                              font=ctk.CTkFont(size=10), text_color=COLORS["success"])
        self.validation_label.grid(row=2, column=0, padx=15, pady=(0, 5), sticky="w")

        btn_row = ctk.CTkFrame(query_card, fg_color="transparent")
        btn_row.grid(row=3, column=0, padx=15, pady=(5, 15), sticky="w")

        ctk.CTkButton(btn_row, text="▶ Rechercher", font=ctk.CTkFont("Consolas", 12, "bold"),
