            row=1, column=0, padx=20, pady=(0, 12), sticky="w")

        content = ctk.CTkScrollableFrame(self, fg_color=COLORS["bg_dark"])
        content.grid(row=1, column=0, sticky="nsew", padx=0, pady=0)
        content.grid_columnconfigure(0, weight=1)

