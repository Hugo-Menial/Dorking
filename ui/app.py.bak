            "title": "Opérateurs de contenu",
            "color": "#A855F7", "icon": "📄",
            "intro": "Ciblent le contenu dans le titre HTML, l'URL ou le corps de la page.",
            "entries": [
                {
                    "op": "intitle:",
                    "syntax": "intitle:texte",
                    "desc": "Recherche le texte dans la balise <title> de la page. allintitle: impose que TOUS les mots y soient présents.",
                    "examples": [
                        ("Panneaux admin",          'intitle:"admin panel"'),
                        ("Pages de login",          'intitle:"login" site:example.com'),
                        ("Index de répertoires",    'intitle:"index of" "parent directory"'),
                        ("Caméras IP AXIS",         'intitle:"Live View / - AXIS"'),
                    ],
                    "tip": 'intitle:"index of" est l\'une des techniques les plus puissantes : elle détecte les serveurs avec directory listing actif.',
                },
                {
                    "op": "inurl:",
                    "syntax": "inurl:chemin",
                    "desc": "Recherche le texte dans l'URL de la page. Correspondance partielle. allinurl: impose tous les termes.",
                    "examples": [
                        ("Panels d'administration", "inurl:admin"),
                        ("Pages de config PHP",     "inurl:config.php"),
                        ("APIs exposées",           'inurl:"/api/v1/" site:example.com'),
                        ("phpMyAdmin",              'inurl:phpmyadmin intitle:"phpMyAdmin"'),
                    ],
                    "tip": "inurl: cherche une correspondance partielle dans toute l'URL. Mettez entre guillemets pour forcer le chemin exact.",
                },
                {
                    "op": "intext:",
                    "syntax": "intext:texte",
                    "desc": "Recherche le texte dans le corps de la page (hors titre et URL). allintext: impose tous les termes.",
                    "examples": [
                        ("Credentials exposés",     'intext:"password=" intext:"username="'),
                        ("Clés API dans le code",   'intext:"api_key" site:example.com'),
                        ("Erreurs MySQL",            'intext:"SQL syntax" intext:"mysql_fetch"'),
                        ("Stack traces",             'intext:"Exception in thread" filetype:log'),
                    ],
                    "tip": "Combinez intext: avec site: pour auditer le contenu d'un domaine spécifique sans bruit externe.",
                },
                {
                    "op": "inanchor:",
                    "syntax": "inanchor:texte",
                    "desc": "Recherche le texte dans les ancres de liens (<a href=...>texte</a>) pointant vers une page.",
                    "examples": [
                        ("Liens vers login",        'inanchor:"login" site:example.com'),
                        ("Backlinks avec mot-clé",  'inanchor:"download" filetype:zip'),
                    ],
                    "tip": "Moins utilisé mais utile pour cartographier les liens internes d'un site ou trouver des pages peu visibles.",
                },
            ],
        },
        {
            "id": "logic",
            "title": "Logique & Syntaxe",
            "color": "#FFD700", "icon": "⚙️",
            "intro": "Modificateurs logiques pour combiner, exclure et préciser les requêtes.",
            "entries": [
                {
                    "op": '"phrase exacte"',
                    "syntax": '"mot1 mot2 mot3"',
                    "desc": "Force la recherche de la séquence exacte de mots. Indispensable pour chercher des patterns de sécurité précis.",
                    "examples": [
                        ("Clé privée RSA",          '"-----BEGIN RSA PRIVATE KEY-----"'),
                        ("Header Authorization",    '"Authorization: Bearer" site:example.com'),
                        ("Message d\'erreur exact", '"ORA-00933: SQL command not properly ended"'),
                        ("Credentials dans logs",   '"username" "password" filetype:log'),
                    ],
                    "tip": "La phrase exacte est l'outil n°1 pour les patterns de sécurité : tokens, clés, messages d'erreur, headers HTTP.",
                },
                {
                    "op": "- (NOT / exclusion)",
                    "syntax": "-terme  ou  -site:domaine",
                    "desc": "Exclut les résultats contenant ce terme ou provenant de ce domaine. S'applique à n'importe quel opérateur.",
                    "examples": [
                        ("Exclure un domaine",      "inurl:admin -site:example.com"),
                        ("Éliminer les exemples",   "filetype:env -intext:sample -intext:example"),
                        ("Affiner les index",       'intitle:"index of" -intext:"This site"'),
                        ("Exclure les wikis",       'filetype:sql "password" -site:github.com'),
                    ],
                    "tip": "Enchaînez plusieurs exclusions pour éliminer les faux positifs. Très efficace combiné avec filetype: ou site:.",
                },
                {
                    "op": "OR",
                    "syntax": "terme1 OR terme2",
                    "desc": "Retourne les résultats contenant l'un OU l'autre terme. Le symbole | est un alias de OR.",
                    "examples": [
                        ("Multi-extensions",        "filetype:sql OR filetype:db OR filetype:sqlite"),
                        ("Multi-chemins admin",     "inurl:admin OR inurl:administrator OR inurl:wp-admin"),
                        ("Variantes de secrets",    'site:example.com "passwd" OR "password" OR "credentials"'),
                    ],
                    "tip": "Groupez les OR entre parenthèses pour les combiner proprement : (filetype:sql OR filetype:db) site:example.com",
                },
                {
                    "op": "AROUND(N)",
                    "syntax": "mot1 AROUND(N) mot2",
                    "desc": "Les deux mots doivent apparaître à moins de N mots l'un de l'autre dans le texte. N est un entier.",
                    "examples": [
                        ("Credentials proches",     "password AROUND(3) username"),
                        ("CVE dans contexte",        "vulnerability AROUND(5) CVE"),
                        ("Secrets de config",        "secret AROUND(4) key"),
                    ],
                    "tip": "N=3 à 5 est optimal. Plus N est petit, plus le résultat est ciblé. N > 10 revient presque à une recherche libre.",
                },
                {
                    "op": "* (wildcard)",
                    "syntax": '"mot * mot"',
                    "desc": "Dans une phrase exacte entre guillemets, * remplace exactement un mot inconnu.",
                    "examples": [
                        ("Token Bearer variable",   '"Bearer *" site:example.com'),
                        ("Variable d\'environnement",'filetype:env "DB_* ="'),
                        ("Titre de panel variable", 'intitle:"* admin panel"'),
                    ],
                    "tip": "Le wildcard * ne fonctionne QUE dans les guillemets. En dehors, Google l'ignore complètement.",
                },
            ],
        },
        {
            "id": "advanced",
            "title": "Techniques avancées",
            "color": "#FF6B35", "icon": "🔬",
            "intro": "Patterns éprouvés pour l'audit de sécurité et la reconnaissance OSINT.",
            "entries": [
                {
                    "op": "Directory listing",
                    "syntax": 'intitle:"index of"',
                    "desc": "Détecte les serveurs web avec le listing de répertoires activé (misconfiguration critique).",
                    "examples": [
                        ("Répertoires ouverts",     'intitle:"index of" site:example.com'),
                        ("Backups exposés",          'intitle:"index of" "backup" OR ".bak"'),
                        ("Logs accessibles",         'intitle:"index of" "access.log" OR "error.log"'),
                        ("Clés et certificats",      'intitle:"index of" ".key" OR ".pem" OR ".crt"'),
                    ],
                    "tip": "Un directory listing non intentionnel expose TOUT le contenu du répertoire. C'est une misconfiguration critique souvent présente.",
                },
                {
                    "op": "Fichiers de config",
                    "syntax": "filetype:env OR filetype:yml",
                    "desc": "Trouve les fichiers de configuration exposés : credentials, tokens API, URLs de base de données.",
                    "examples": [
                        ("Fichiers .env",            'filetype:env "DB_PASSWORD" OR "SECRET_KEY"'),
                        ("Configs PHP",              'filetype:php intext:"define(" intext:"password"'),
                        ("YAML avec secrets",        'filetype:yaml "password:" OR "secret:" OR "token:"'),
                        ("Fichiers .htpasswd",       "filetype:htpasswd"),
                    ],
                    "tip": ".env, .htpasswd, wp-config.php et database.yml sont les fichiers les plus souvent mal protégés sur des hébergements partagés.",
                },
                {
                    "op": "Panneaux d'admin",
                    "syntax": 'inurl:admin intitle:"login"',
                    "desc": "Localise les interfaces d'administration et portails d'accès exposés sur un domaine cible.",
                    "examples": [
                        ("Admin générique",          'site:target.com inurl:admin intitle:"login"'),
                        ("phpMyAdmin",               'inurl:phpmyadmin intitle:"phpMyAdmin"'),
                        ("Panels WordPress",         "inurl:wp-admin site:target.com"),
                        ("Portail Apache Tomcat",    'intitle:"Apache Tomcat" inurl:manager'),
                    ],
                    "tip": "Remplacez target.com par votre cible. Vérifiez toujours une autorisation écrite avant tout test d'accès.",
                },
                {
                    "op": "Secrets & clés exposés",
                    "syntax": '"api_key" filetype:env',
                    "desc": "Détecte des patterns caractéristiques de clés API, tokens OAuth et secrets dans des fichiers indexés.",
                    "examples": [
                        ("Clé privée RSA",           '"-----BEGIN RSA PRIVATE KEY-----"'),
                        ("AWS Access Key",           '"AKIA" filetype:env OR filetype:yml'),
                        ("Tokens GitHub",            '"ghp_" OR "github_pat_" filetype:env'),
                        ("Clés génériques en JS",   'intext:"api_key" filetype:js site:target.com'),
