                        ("CV et profils exposés",    'site:target.com filetype:pdf "curriculum vitae" OR "resume"'),
                        ("Organigrammes",            'site:target.com filetype:pdf "organigramme" OR "org chart"'),
                        ("Comptes LinkedIn",         'site:linkedin.com/in "target company"'),
