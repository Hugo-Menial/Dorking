                       hover_color="#00A8CC", height=38, width=160,
                       command=self._search).pack(side="left", padx=(0, 8))

        ctk.CTkButton(btn_row, text="📋 Copier", font=ctk.CTkFont("Consolas", 12),
                       fg_color=COLORS["bg_input"], text_color=COLORS["text"],
                       hover_color=COLORS["border"], height=38, width=100,
                       command=self._copy).pack(side="left", padx=(0, 8))

        ctk.CTkButton(btn_row, text="🌐 Navigateur", font=ctk.CTkFont("Consolas", 12),
                       fg_color=COLORS["accent3"], text_color="white",
                       hover_color="#9333EA", height=38, width=140,
                       command=self._open_browser).pack(side="left", padx=(0, 8))

        ctk.CTkButton(btn_row, text="📄 Rapport HTML", font=ctk.CTkFont("Consolas", 12),
