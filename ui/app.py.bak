                        ("Tous les sous-domaines",   "site:*.target.com"),
                        ("Portails d'accès distant", "site:target.com inurl:vpn OR inurl:citrix OR inurl:rdweb"),
                        ("Technologies détectées",   'site:target.com intitle:"Apache" OR intitle:"nginx" OR intitle:"IIS"'),
                        ("Documents publics",        "site:target.com filetype:pdf OR filetype:docx"),
