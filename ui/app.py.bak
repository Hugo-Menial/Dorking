                       hover_color="#CC5522", height=38, width=150,
                       command=self._open_smart_redirector).pack(side="left", padx=(0, 8))

        ctk.CTkButton(btn_row, text="🗑 Effacer", font=ctk.CTkFont("Consolas", 12),
                       fg_color=COLORS["bg_input"], text_color=COLORS["text"],
                       hover_color=COLORS["border"], height=38, width=100,
                       command=lambda: self.query_var.set("")).pack(side="left")

        ops_card = ctk.CTkFrame(content, fg_color=COLORS["bg_card"], corner_radius=8)
        ops_card.grid(row=1, column=0, padx=20, pady=10, sticky="ew")
        ops_card.grid_columnconfigure(tuple(range(4)), weight=1)

        ctk.CTkLabel(ops_card, text="Opérateurs rapides",
                      font=ctk.CTkFont("Consolas", 13, "bold"), text_color=COLORS["text"]).grid(
            row=0, column=0, columnspan=4, padx=15, pady=(12, 8), sticky="w")

